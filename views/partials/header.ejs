<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>County Reports</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light d-flex flex-column min-vh-100">

  <nav class="navbar navbar-dark bg-dark px-4">
    <a class="navbar-brand fw-bold" href="/">🏛️ County Reports</a>
    <div>
      <% if (typeof user !== 'undefined' && user) { %>
        <span class="text-white me-3"><%= user.email %></span>
        <% if (user.role === 'admin') { %>
          <span class="badge bg-warning text-dark me-3">Admin</span>
        <% } %>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      <% } else { %>
        <a href="/login" class="btn btn-outline-light btn-sm me-2">Login</a>
        <a href="/register" class="btn btn-light btn-sm">Register</a>
      <% } %>
    </div>
  </nav>