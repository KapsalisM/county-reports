<%- include('partials/header', { user: user }) %>

  <div class="container mt-4">

    <!-- SUBMIT FORM -->
    <div class="card mb-5 shadow-sm">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0">📋 Submit a New Report</h5>
      </div>
      <div class="card-body">
        <form action="/report" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input type="text" name="title" class="form-control"
              placeholder="e.g. Tree fell on Main Street" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="category" class="form-select">
              <option value="road">Road Problem</option>
              <option value="drainage">Drainage / Water</option>
              <option value="electricity">Electricity</option>
              <option value="parks">Parks & Trees</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="3"
              placeholder="Describe the problem in detail..." required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Upload Image <span class="text-muted">(optional)</span></label>
            <input type="file" name="image" class="form-control" accept="image/*">
          </div>
          <div class="mb-3">
            <label class="form-label">Location</label>
            <input type="text" id="address-input" name="address" class="form-control" 
            placeholder="Start typing a street address...">
            <input type="hidden" name="latitude" id="latitude">
            <input type="hidden" name="longitude" id="longitude">
          </div>
          <div class="mb-3">
            <div id="report-map" style="height: 300px; border-radius: 12px;"></div>
          </div>
          <button type="submit" class="btn btn-primary">Submit Report</button>
        </form>
      </div>
    </div>

    <!-- ALL REPORTS -->
    <h4 class="mb-3">🗺️ Community Reports</h4>
    <% if (reports.length === 0) { %>
      <p class="text-muted">No reports yet. Be the first to submit one!</p>
    <% } else { %>
      <div class="row">
        <% reports.forEach(report => { %>
          <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">

              <!-- IMAGE ON TOP -->
              <% if (report.image) { %>
                <div class="position-relative">
                  <img src="/uploads/<%= report.image %>"
                       class="card-img-top"
                       style="height: 200px; object-fit: cover;">
                  <div class="position-absolute bottom-0 start-0 w-100 px-3 py-2"
                       style="background: rgba(0,0,0,0.55);">
                    <h6 class="text-white fw-bold mb-0"><%= report.title %></h6>
                    <% if (report.address) { %>
                      <small class="text-white-50">📍 <%= report.address %></small>
                    <% } %>
                  </div>
                </div>
              <% } else { %>
                <div class="d-flex flex-column justify-content-center px-3 py-3"
                     style="background-color: #495057; border-radius: 12px 12px 0 0; min-height: 80px;">
                  <h6 class="text-white fw-bold mb-0"><%= report.title %></h6>
                  <% if (report.address) { %>
                    <small class="text-white-50">📍 <%= report.address %></small>
                  <% } %>
                </div>
              <% } %>

              <!-- CARD BODY -->
              <div class="card-body">

                <!-- BADGES -->
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <span class="badge bg-secondary">🗂️ <%= report.category %></span>
                  <% if (report.status === 'solved') { %>
                    <span class="badge bg-success">✅ Solved</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">⚠️ Open</span>
                  <% } %>
                  <% if (report.danger_level === 'high') { %>
                    <span class="badge bg-danger">🔴 High Danger</span>
                  <% } else if (report.danger_level === 'medium') { %>
                    <span class="badge" style="background-color: #fd7e14; color: white;">🟠 Medium Danger</span>
                  <% } else { %>
                    <span class="badge bg-success">🟢 Low Danger</span>
                  <% } %>
                </div>

                <!-- DESCRIPTION -->
                <p class="card-text"><%= report.description %></p>

                <!-- REPORTER INFO -->
                <small class="text-muted">
                  👤 <%= report.email %> &nbsp;|&nbsp;
                  📅 <%= new Date(report.created_at).toLocaleDateString() %>
                </small>

              </div>

              <!-- ADMIN BUTTONS -->
              <% if (user.role === 'admin') { %>
                <div class="card-footer d-flex gap-2">
                  <% if (report.status !== 'solved') { %>
                    <form action="/report/solve/<%= report.id %>" method="POST">
                      <button class="btn btn-success btn-sm">✅ Mark as Solved</button>
                    </form>
                  <% } %>
                  <form action="/report/delete/<%= report.id %>" method="POST">
                    <button class="btn btn-danger btn-sm">🗑️ Delete</button>
                  </form>
                </div>
              <% } %>

            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>

  <!-- MAP SCRIPT -->
  <script>
    let map, marker;

    function initMap() {
      const defaultLocation = { lat: 37.9838, lng: 23.7275 };

      map = new google.maps.Map(document.getElementById("report-map"), {
        zoom: 13,
        center: defaultLocation,
      });

      marker = new google.maps.Marker({
        map: map,
        draggable: true,
      });

      map.addListener("click", (e) => {
        placeMarker(e.latLng);
      });

      marker.addListener("dragend", () => {
        updateCoords(marker.getPosition());
      });

      const input = document.getElementById("address-input");
      const autocomplete = new google.maps.places.Autocomplete(input);
      autocomplete.addListener("place_changed", () => {
        const place = autocomplete.getPlace();
        if (!place.geometry) return;
        map.setCenter(place.geometry.location);
        map.setZoom(16);
        placeMarker(place.geometry.location);
      });
    }

    function placeMarker(location) {
      marker.setPosition(location);
      updateCoords(location);
    }

    function updateCoords(location) {
      document.getElementById("latitude").value = location.lat();
      document.getElementById("longitude").value = location.lng();
    }
  </script>

<%- include('partials/footer') %>