<%- include('partials/header', { user: user }) %>

  <!-- HERO -->
  <section class="hero">
    <h1>Welcome to County Reports</h1>
    <p>Help us improve our community. Report local problems and track their progress.</p>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard" class="btn btn-primary btn-lg me-2">Go to Dashboard</a>
    <% } else { %>
      <a href="/register" class="btn btn-primary btn-lg me-2">Get Started</a>
      <a href="/login" class="btn btn-outline-light btn-lg">Login</a>
    <% } %>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="container">
      <div class="row text-center">
        <div class="col-4">
          <h4 class="fw-bold mb-0"><%= reports.length %></h4>
          <small>Total Reports</small>
        </div>
        <div class="col-4">
          <h4 class="fw-bold mb-0"><%= reports.filter(r => r.status === 'open').length %></h4>
          <small>Open</small>
        </div>
        <div class="col-4">
          <h4 class="fw-bold mb-0"><%= reports.filter(r => r.status === 'solved').length %></h4>
          <small>Solved</small>
        </div>
      </div>
    </div>
  </section>

  <div class="container mt-5 mb-5">

    <!-- MAP SECTION -->
    <h4 class="mb-3">📍 Problem Map</h4>
    <div id="home-map" style="height: 450px; border-radius: 12px;" class="mb-5 shadow-sm"></div>

    <!-- LATEST REPORTS -->
    <h4 class="mb-3">🗺️ Latest Community Reports</h4>
    <% if (reports.length === 0) { %>
      <div class="text-center py-5 text-muted">
        <h5>No reports yet.</h5>
        <p>Be the first to report a problem in your community!</p>
        <a href="/register" class="btn btn-primary">Register & Report</a>
      </div>
    <% } else { %>
      <div class="row">
        <% reports.forEach(report => { %>
          <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">

              <!-- IMAGE ON TOP -->
              <% if (report.image) { %>
                <div class="position-relative">
                  <img src="/uploads/<%= report.image %>"
                       class="card-img-top"
                       style="height: 200px; object-fit: cover;">
                  <div class="position-absolute bottom-0 start-0 w-100 px-3 py-2"
                       style="background: rgba(0,0,0,0.55);">
                    <h6 class="text-white fw-bold mb-0"><%= report.title %></h6>
                    <% if (report.address) { %>
                      <small class="text-white-50">📍 <%= report.address %></small>
                    <% } %>
                  </div>
                </div>
              <% } else { %>
                <div class="d-flex flex-column justify-content-center px-3 py-3"
                     style="background-color: #495057; border-radius: 12px 12px 0 0; min-height: 80px;">
                  <h6 class="text-white fw-bold mb-0"><%= report.title %></h6>
                  <% if (report.address) { %>
                    <small class="text-white-50">📍 <%= report.address %></small>
                  <% } %>
                </div>
              <% } %>

              <!-- CARD BODY -->
              <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <span class="badge bg-secondary">🗂️ <%= report.category %></span>
                  <% if (report.status === 'solved') { %>
                    <span class="badge bg-success">✅ Solved</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">⚠️ Open</span>
                  <% } %>
                  <% if (report.danger_level === 'high') { %>
                    <span class="badge bg-danger">🔴 High Danger</span>
                  <% } else if (report.danger_level === 'medium') { %>
                    <span class="badge" style="background-color: #fd7e14; color: white;">🟠 Medium Danger</span>
                  <% } else { %>
                    <span class="badge bg-success">🟢 Low Danger</span>
                  <% } %>
                </div>
                <p class="card-text"><%= report.description %></p>
                <small class="text-muted">
                  👤 <%= report.email %> &nbsp;|&nbsp;
                  📅 <%= new Date(report.created_at).toLocaleDateString() %>
                </small>
              </div>

            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- MAP SCRIPT -->
  <script>
    // Pass reports from server to JavaScript
    const reports = <%- reportsJson %>;

    window.addEventListener("load", function() {
      initMap();
    });

    function initMap() {
      const defaultLocation = { lat: 37.9838, lng: 23.7275 };

      const map = new google.maps.Map(document.getElementById("home-map"), {
        zoom: 12,
        center: defaultLocation,
      });

      // Color of pin based on danger level
      function getPinColor(danger) {
        if (danger === "high") return "http://maps.google.com/mapfiles/ms/icons/red-dot.png";
        if (danger === "medium") return "http://maps.google.com/mapfiles/ms/icons/orange-dot.png";
        return "http://maps.google.com/mapfiles/ms/icons/green-dot.png";
      }

      // Add a pin for each report that has coordinates
      reports.forEach(report => {
        if (!report.latitude || !report.longitude) return;

        const marker = new google.maps.Marker({
          position: { lat: parseFloat(report.latitude), lng: parseFloat(report.longitude) },
          map: map,
          title: report.title,
          icon: getPinColor(report.danger_level)
        });

        // Popup when clicking a pin
        const infoWindow = new google.maps.InfoWindow({
          content: `
            <div style="max-width: 220px;">
              <h6 style="margin: 0 0 6px 0;">${report.title}</h6>
              <p style="margin: 0 0 6px 0; font-size: 13px;">${report.description}</p>
              <span style="font-size: 12px; color: #666;">📍 ${report.address || "No address"}</span><br>
              <span style="font-size: 12px; color: #666;">Status: <strong>${report.status}</strong></span>
            </div>
          `
        });

        marker.addListener("click", () => {
          infoWindow.open(map, marker);
        });
      });
    }
  </script>

<%- include('partials/footer') %>